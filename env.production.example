ENVIRONMENT=prod
POSTGRES_DB=access_poc
POSTGRES_USER=access_app
POSTGRES_PASSWORD=replace-with-strong-postgres-password
DATABASE_URL=postgresql://access_app:replace-with-strong-postgres-password@postgres:5432/access_poc
REDIS_URL=redis://redis:6379/0
ADMIN_API_KEY=replace-with-strong-admin-key-min-24-chars
METRICS_API_KEY=replace-with-strong-metrics-key-min-24-chars
JWT_ACTIVE_KID=v2
JWT_KEYRING_JSON={"v2":"replace-with-strong-jwt-signing-secret-min-32-chars"}
SECRET_ENCRYPTION_KEY=replace-with-strong-fernet-secret-use-script-output
IP_HASH_PEPPER=replace-with-strong-ip-pepper-min-24-chars
WEBHOOK_SECRET_PEPPER=replace-with-strong-webhook-pepper-min-24-chars
UVICORN_WORKERS=2
